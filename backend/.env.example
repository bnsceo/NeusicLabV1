# Neusic Agent backend — copy to .env and fill in. Never commit real keys.
NEUSIC_ALLOWED_ORIGINS=https://bnsceo.github.io,http://localhost:8080,http://127.0.0.1:8080
HERMES_API_URL=            # optional: your hosted Hermes endpoint
HERMES_API_KEY=            # optional: key for the hosted endpoint
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
MEMORY_DB_PATH=./neusic_memory.sqlite3
